# ============================================================
# Market Intelligence Terminal — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ----- Database (PostgreSQL + TimescaleDB) -----
DATABASE_URL=postgresql://market_user:market_pass_2024@localhost:5432/market_intelligence

# ----- Ollama (Local LLM Runtime) -----
OLLAMA_BASE_URL=http://localhost:11434

# LLM model roles:
#   - ANALYST model  = deep financial reasoning (answers user questions)
#   - ROUTER model   = fast intent classification (routes queries)
LLM_ANALYST_MODEL=llama3
LLM_ROUTER_MODEL=mistral

# ----- API Server -----
API_HOST=0.0.0.0
API_PORT=8000

# ----- Data Pipeline -----
DATA_START_DATE=1990-01-01
SP500_ENABLED=true
CRYPTO_ENABLED=true

# ----- Scheduler (Daily Auto-Update) -----
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=16
SCHEDULER_MINUTE=30
